{
  "manifest_version": 3,
  "name": "Windchill URL Helper (proto)",
  "version": "0.1.0",
  "description": "Windchill URL tools for context-menu copy actions, infoFromPA=true, and jcaDebug=1.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Windchill URL Helper"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://*/Windchill/*",
    "*://*/windchill/*",
    "*://*/WINDCHILL/*"
  ]
}
