{
  "manifest_version": 3,
  "name": "Windchill Helper",
  "version": "0.6.0",
  "description": "Productivity tools for PTC Windchill: copy OR/VR references, object info, URLs, and display full user/group info.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Windchill Helper",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://*/Windchill/*",
    "*://*/windchill/*",
    "*://*/WINDCHILL/*"
  ]
}
