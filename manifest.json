{
  "manifest_version": 3,
  "name": "Windchill URL Helper (proto)",
  "version": "0.1.0",
  "description": "Adds infoFromPA=true and jcaDebug=1 to the current Windchill tab URL.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Windchill URL Helper"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "contextMenus"],
  "host_permissions": ["*://*/Windchill/*", "*://*/windchill/*"]
}
